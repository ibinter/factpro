# ═══════════════════════════════════════════════════════════════
#  IBIG FactPro — Template .env Production
#  Copier ce fichier en .env et remplir toutes les valeurs
#  NE JAMAIS committer le .env réel dans Git
#  Voir docs/deployment/ENV-REFERENCE.md pour la référence complète
# ═══════════════════════════════════════════════════════════════

# ─── Core Application ───────────────────────────────────────────
APP_NAME="IBIG FactPro"
APP_ENV=production
APP_KEY=                                    # php artisan key:generate
APP_DEBUG=false
APP_URL=https://votre-domaine.com           # Avec https:// obligatoire
APP_TIMEZONE=Africa/Abidjan                 # Africa/Dakar | Africa/Douala | Europe/Paris | UTC

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ─── Logging ────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                             # error en production (pas debug)

# LOG_SLACK_WEBHOOK_URL=                    # Optionnel : alertes Slack

# ─── Base de données ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=factpro_prod
DB_USERNAME=factpro_user
DB_PASSWORD=                                # Mot de passe fort requis

# ─── Session ────────────────────────────────────────────────────
SESSION_DRIVER=database                     # redis sur VPS
SESSION_LIFETIME=480                        # 8 heures (usage professionnel)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null                         # .votre-domaine.com pour sous-domaines

# ─── Cache ──────────────────────────────────────────────────────
CACHE_STORE=file                            # redis sur VPS — file sur mutualisé

# ─── Queues ─────────────────────────────────────────────────────
# VPS avec Redis    : QUEUE_CONNECTION=redis
# VPS sans Redis    : QUEUE_CONNECTION=database
# Mutualisé cPanel  : QUEUE_CONNECTION=sync
QUEUE_CONNECTION=database

# ─── Redis (VPS uniquement) ─────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null                         # Configurer un mot de passe Redis en prod
REDIS_PORT=6379

# ─── Broadcast (désactivé par défaut) ───────────────────────────
BROADCAST_CONNECTION=log
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=
# REVERB_PORT=443
# REVERB_SCHEME=https

# ─── Email ──────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.votre-fournisseur.com        # smtp.mailgun.org | smtp.sendgrid.net | mail.votre-domaine.com
MAIL_PORT=587                               # 587 (STARTTLS) | 465 (SSL) | 25
MAIL_USERNAME=factpro@votre-domaine.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=factpro@votre-domaine.com
MAIL_FROM_NAME="IBIG FactPro"

# Mailgun (alternative SMTP)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=votre-domaine.com
# MAILGUN_SECRET=
# MAILGUN_ENDPOINT=api.eu.mailgun.net       # api.eu.mailgun.net pour Europe/Afrique

# ─── Stockage de fichiers ────────────────────────────────────────
FILESYSTEM_DISK=local
PROOF_STORAGE_DISK=local
PROOF_MAX_SIZE_MB=10

# Amazon S3 (optionnel, pour stockage cloud)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=factpro-prod-files
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Fonctionnalités FactPro ─────────────────────────────────────
VERIFY_BASE_URL=https://votre-domaine.com/verify

# ─── Licences & Essai gratuit ────────────────────────────────────
TRIAL_DURATION_DAYS=7
LICENSE_GRACE_PERIOD_DAYS=7
LICENSE_PROVISIONAL_MAX_DAYS=7

# ─── Anti-fraude ────────────────────────────────────────────────
FRAUD_ALERT_EMAIL=admin@votre-domaine.com
FRAUD_AMOUNT_TOLERANCE_PERCENT=5

# ═══════════════════════════════════════════════════════════════
#  PASSERELLES DE PAIEMENT
#  Configurer uniquement les passerelles utilisées dans votre pays
#  Laisser vide = passerelle désactivée
# ═══════════════════════════════════════════════════════════════

# ─── Moneroo (CI, SN, CM, GN, BF, ML, TG, BJ…) ────────────────
MONEROO_PUBLIC_KEY=
MONEROO_SECRET_KEY=
MONEROO_WEBHOOK_SECRET=                     # Générer : openssl rand -hex 32
MONEROO_MODE=live                           # sandbox | live

# ─── CinetPay (CI, SN, CM, ML, BF, TG, GN, RDC…) ─────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_MODE=PRODUCTION                    # TEST | PRODUCTION

# ─── FedaPay (BJ, TG, SN) ───────────────────────────────────────
FEDAPAY_SECRET_KEY=
FEDAPAY_MODE=live                           # sandbox | live

# ─── Flutterwave (NG, GH, KE, ZA, UG, TZ, RW, ZM…) ───────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_HASH=                           # Secret de vérification webhook

# ─── Stripe (International, France, Europe) ─────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════
#  SMS & WHATSAPP (optionnel)
# ═══════════════════════════════════════════════════════════════

# ─── Africa's Talking (SMS — Afrique) ───────────────────────────
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# ─── Twilio (SMS + WhatsApp) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# ═══════════════════════════════════════════════════════════════
#  FONCTIONNALITÉS AVANCÉES (optionnel)
# ═══════════════════════════════════════════════════════════════

# OCR factures fournisseurs (Google Vision)
# GOOGLE_VISION_KEY=

# Taux de change — fallback open.er-api.com si vide
# EXCHANGE_RATE_API_KEY=

# ─── Front-end (Vite) ────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
